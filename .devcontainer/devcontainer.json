{
  "name": "Ansible Zero to Hero",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "ansible.python.interpreterPath": "/opt/app-root/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "adt --version",
  "remoteUser": "default"
}
